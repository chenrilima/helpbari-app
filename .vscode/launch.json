    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "helpbari",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "helpbari (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "helpbari (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {
            "name": "HelpBari DEV",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=ENV=dev"
                    ]
        },
        {
            "name": "HelpBari STAGING",
            "request": "launch",
            "type": "dart",
            "args": [
                "--dart-define=ENV=staging"
                     ]
        },
        {
            "name": "HelpBari PROD",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "args": [
                "--dart-define=ENV=prod"
                    ]
        }
                    ]
}